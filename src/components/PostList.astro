---
import type { CollectionEntry } from 'astro:content';
import Post from './Post.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

<ul style="list-style: none; padding: 0; margin: 0;">
  {
    posts.map((post) => (
      <Post post={post} />
    ))
  }
</ul>
