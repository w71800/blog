# 正式站網址（sitemap、canonical 用）。部署到 Zeabur 後改成你的域名。
PUBLIC_SITE_URL=https://example.com

# Giscus：https://giscus.app/zh-TW 設定後填入
# 格式：owner/repo
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPO_ID=
# Discussions 分類名稱（需與 GitHub 設定一致）
PUBLIC_GISCUS_CATEGORY=Announcements
PUBLIC_GISCUS_CATEGORY_ID=
# 可選：pathname | url | title | og:title
PUBLIC_GISCUS_MAPPING=pathname
# 可選：zh-TW | en 等
PUBLIC_GISCUS_LANG=zh-TW
